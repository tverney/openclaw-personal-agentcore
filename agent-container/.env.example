# Discord Bot Token (used by EC2 bot, not the container)
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# AWS Configuration
AWS_REGION=us-east-2

# Bedrock Model Configuration
# Recommended models (must use inference profile IDs with region prefix):
# - us.anthropic.claude-3-5-haiku-20241022-v1:0  (fast, cheap — recommended)
# - us.amazon.nova-lite-v1:0                      (cheapest)
# - us.anthropic.claude-sonnet-4-20250514-v1:0    (most capable, expensive)
BEDROCK_MODEL_ID=us.anthropic.claude-3-5-haiku-20241022-v1:0
