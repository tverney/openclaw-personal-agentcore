# ============================================================================
# OpenClaw Agent Container Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Discord Bot Token (used by EC2 bot, not the container)
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# AWS Configuration
AWS_REGION=us-east-2

# Bedrock Model Configuration
# Must use inference profile IDs with region prefix (us., eu., global.)
# Examples:
#   us.anthropic.claude-3-5-haiku-20241022-v1:0  (fast, cheap — recommended)
#   us.amazon.nova-lite-v1:0                      (cheapest)
#   us.anthropic.claude-sonnet-4-20250514-v1:0    (most capable, expensive)
BEDROCK_MODEL_ID=us.anthropic.claude-3-5-haiku-20241022-v1:0

# OpenClaw Authentication Token
# Generate a secure token: openssl rand -hex 32
# If not set, falls back to an insecure default (dev only).
OPENCLAW_AUTH_TOKEN=

# Optional: S3 bucket for session persistence (leave empty to disable)
SESSION_BACKUP_BUCKET=

# Optional: S3 sync interval in seconds (default: 300)
SYNC_INTERVAL_SECONDS=300

# ============================================================================
# Validation Commands
# ============================================================================
# 1. Check AWS credentials:
#    aws sts get-caller-identity --region $AWS_REGION
#
# 2. Test Bedrock model access:
#    aws bedrock-runtime invoke-model \
#      --model-id $BEDROCK_MODEL_ID \
#      --body '{"messages":[{"role":"user","content":"test"}]}' \
#      --region $AWS_REGION /dev/stdout
#
# 3. Verify S3 bucket access (if configured):
#    aws s3 ls s3://$SESSION_BACKUP_BUCKET --region $AWS_REGION
