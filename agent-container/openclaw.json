{
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "loopback",
    "auth": {
      "token": "${OPENCLAW_AUTH_TOKEN}"
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        }
      }
    }
  },
  "models": {
    "providers": {
      "amazon-bedrock": {
        "baseUrl": "https://bedrock-runtime.${AWS_REGION}.amazonaws.com",
        "api": "bedrock-converse-stream",
        "auth": "aws-sdk",
        "models": [
          {
            "id": "${BEDROCK_MODEL_ID}",
            "name": "Bedrock Model",
            "input": [
              "text"
            ],
            "contextWindow": 200000,
            "maxTokens": 8192,
            "reasoning": false
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "amazon-bedrock/${BEDROCK_MODEL_ID}"
      }
    }
  },
  "skills": {
    "load": {
      "watch": true,
      "watchDebounceMs": 250
    },
    "entries": {
      "humanizer": {
        "enabled": true
      },
      "tavily": {
        "enabled": true,
        "env": {
          "TAVILY_API_KEY": "${TAVILY_API_KEY}"
        }
      },
      "gog": {
        "enabled": true,
        "env": {
          "GOG_ACCOUNT": "${GOG_ACCOUNT}",
          "GOG_KEYRING_PASSWORD": "${GOG_KEYRING_PASSWORD}"
        }
      },
      "memory": {
        "enabled": true
      },
      "weather": {
        "enabled": true
      },
      "alexa-cli": {
        "enabled": true
      },
      "my-weather": {
        "enabled": true
      },
      "notes-reminders": {
        "enabled": true
      },
      "personal-assistant": {
        "enabled": true
      },
      "soccer-cli": {
        "enabled": true
      },
      "stock-watcher": {
        "enabled": true
      },
      "tmux": {
        "enabled": true
      }
    }
  }
}
