# ============================================================================
# Discord Bot Configuration
# ============================================================================
# SECURITY: Never commit this file to version control.

# Required: Discord Bot Token (from Discord Developer Portal)
# https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Required: AgentCore Runtime ARN (from CloudFormation outputs)
AGENTCORE_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-2:123456789012:runtime/your-runtime-id

# Required: AWS Region (must match AgentCore Runtime region)
AWS_REGION=us-east-2

# Optional: AWS Profile (if not using default)
# AWS_PROFILE=default

# ============================================================================
# Validation
# ============================================================================
# 1. Verify AWS access:
#    aws sts get-caller-identity --region $AWS_REGION
#
# 2. Verify AgentCore Runtime:
#    aws bedrock-agentcore describe-runtime \
#      --runtime-id $(echo $AGENTCORE_RUNTIME_ARN | cut -d'/' -f2) \
#      --region $AWS_REGION
